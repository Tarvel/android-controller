# ── Provider Selection ──
# Set to "anthropic", "deepseek", or "auto" (detects from available keys)
ACC_PROVIDER=auto

# ── Anthropic (Claude) ──
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── DeepSeek ──
# Get your key at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# ── General Settings ──
ACC_DEBUG=false
ACC_SECRET_KEY=change-me-in-production
ACC_DEFAULT_MODE=auto
ACC_MAX_STEPS=20
ACC_SAFE_MODE=true
ACC_SCREENSHOT_QUALITY=70
